# ============================================================
# Back_Iara — variáveis de ambiente (copie para .env e preencha)
# Nada de segredo real vai versionado. .env está no .gitignore.
# ============================================================

# --- Ambiente ---
NODE_ENV=development
LOG_LEVEL=debug

# --- Banco de dados (Postgres + pgvector) ---
# Local via Infra_Iara (docker-compose) na porta 5433, OU Neon na nuvem.
DATABASE_URL="postgresql://iara:iara@localhost:5433/iara?schema=public"

# --- Fila / Redis (BullMQ) ---
REDIS_URL="redis://localhost:6379"

# --- API ---
API_PORT=3333
API_BASE_URL="http://localhost:3333"

# --- Criptografia de tokens sociais (KMS / fallback local) ---
TOKEN_ENC_KEY="32-bytes-base64-troque-isto-em-prod"

# --- Seleção de providers: mock = funcional sem chave; real = precisa da chave ---
PROVIDER_IMAGE="mock"            # mock | flux
PROVIDER_LLM="mock"              # mock | claude
PROVIDER_DISTRIBUTION="mock"     # mock | ayrshare
PROVIDER_SAFETY="mock"           # mock | real  (motor de texto sempre real; 'real' liga moderador de imagem real)
PROVIDER_CONSISTENCY="mock"      # mock | real  ('real' = embedding facial (cosseno) vs refs aprovadas)

# Gate de consistência facial (limiar 0..1). Abaixo do limiar → item REPROVADO.
CONSISTENCY_THRESHOLD="0.8"

# --- LLM: Claude (Anthropic) — caminho REAL preservado ---
ANTHROPIC_API_KEY=""
LLM_MODEL_STRATEGY="claude-opus-4-8"
LLM_MODEL_VOLUME="claude-haiku-4-5"
FX_USD_BRL="5.40"

# --- Imagem: Flux (Replicate ou Fal) ---
REPLICATE_API_TOKEN=""
FAL_API_KEY=""
FLUX_MODEL="black-forest-labs/flux-dev"

# --- Distribuição: Ayrshare ---
AYRSHARE_API_KEY=""
AYRSHARE_WEBHOOK_SECRET=""

# --- Auth: dev (header x-user-id) | clerk (verifica JWT do Clerk) ---
# Para 'clerk': AUTH_PROVIDER=clerk + CLERK_SECRET_KEY + `npm i @clerk/backend`.
# O e-mail do token Clerk é mapeado para o User do banco. Sem token Bearer, cai no dev header.
AUTH_PROVIDER="dev"              # dev | clerk
CLERK_SECRET_KEY=""

# --- Storage (S3 / Cloudflare R2) ---
# Para s3|r2: STORAGE_PROVIDER + S3_BUCKET/REGION/ACCESS_KEY/SECRET (+ S3_ENDPOINT no R2/MinIO)
# + STORAGE_PUBLIC_BASE_URL (CDN/CloudFront) e `npm i @aws-sdk/client-s3`. local = .storage dev.
STORAGE_PROVIDER="local"         # local | r2 | s3
S3_REGION="auto"
S3_BUCKET="iara-media"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""
STORAGE_PUBLIC_BASE_URL=""       # ex.: https://cdn.iara.ai  (vazio = serve via /storage/* local)

# --- Tetos de custo (guardrails) ---
COST_LIMIT_PERSONA_DAILY_BRL="50"
COST_LIMIT_ORG_DAILY_BRL="200"

# --- Observabilidade (opcional no MVP) ---
SENTRY_DSN=""
