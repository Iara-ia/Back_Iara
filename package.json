{
  "name": "back-iara",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "IARA — API (Fastify) + worker (BullMQ), arquitetura MVC. Pipeline de conteúdo, gates, fila, auth/RBAC multi-tenant.",
  "engines": {
    "node": ">=20"
  },
  "main": "src/api/main.ts",
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:worker",
    "dev:api": "tsx watch --env-file=.env src/api/main.ts",
    "dev:worker": "tsx watch --env-file=.env src/worker/main.ts",
    "start:api": "node dist/api/main.js",
    "start:worker": "node dist/worker/main.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx --env-file=.env prisma/seed.ts",
    "enqueue:test": "tsx --env-file=.env src/worker/enqueueTest.ts",
    "qa:idempotency": "tsx --env-file=.env src/worker/qa/idempotency.ts",
    "qa:retry": "tsx --env-file=.env src/worker/qa/retry.ts",
    "qa:gate-e2e": "tsx --env-file=.env src/worker/qa/gateE2E.ts",
    "qa:gates-real": "tsx --env-file=.env src/worker/qa/gatesReal.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@fastify/cors": "^9.0.1",
    "@prisma/client": "^5.15.0",
    "bullmq": "^5.8.0",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "npm-run-all": "^4.1.5",
    "prisma": "^5.15.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
